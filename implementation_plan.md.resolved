```
src/
├── data/
│   ├── schemas/                    # Zod schemas (fonte de verdade)
│   │   ├── member.schema.ts        # Schema para Member + SocialLinks
│   │   ├── team.schema.ts          # Schema para Team + Athlete
│   │   ├── partner.schema.ts       # Schema para Partner/Sponsor
│   │   └── gallery.schema.ts       # Schema para galeria About
│   │
│   ├── types/                      # TypeScript types (derivados dos schemas)
│   │   └── index.ts                # z.infer<typeof memberSchema> etc.
│   │
│   ├── loaders/                    # Data fetching (Google Sheets API)
│   │   ├── sheets.client.ts        # Client singleton para Sheets API
│   │   ├── loadDirectory.ts        # Fetch + parse diretoria
│   │   ├── loadTeams.ts            # Fetch + parse equipes
│   │   ├── loadPartners.ts         # Fetch + parse patrocinadores
│   │   └── loadGallery.ts          # Fetch + parse galeria
│   │
│   └── utils/
│       ├── cloudinary.ts           # Helper para construir URLs Cloudinary
│       └── normalize.ts            # Normalizar nomes (acentos, hífens)
│
├── lib/
│   └── cloudinary.ts               # Cloudinary config + URL builder
```

### 5.3 Exemplo de Implementação

**Zod Schema (`member.schema.ts`):**

```typescript
import { z } from "zod";

export const socialLinksSchema = z.object({
  instagram: z.string().url().optional(),
  linkedin: z.string().url().optional(),
  twitter: z.string().url().optional(),
  email: z.string().email().optional(),
  github: z.string().optional(),
  personalWebsite: z.string().url().optional(),
});

export const memberSchema = z.object({
  id: z.string(),
  name: z.string().min(2),
  role: z.enum(["president", "vicePresident", "director", "viceDirector", "member"]),
  photo: z.string().url(),         // URL Cloudinary
  photoLarge: z.string().url().optional(),
  sports: z.array(z.string()),     // I18n keys
  course: z.enum(["ec", "cc", "si", "es"]),
  directoryId: z.string().optional(),  // FK para qual diretoria
  socialLinks: socialLinksSchema,
});
```

**Data Loader (`loadDirectory.ts`):**

```typescript
import { google } from "googleapis";
import { memberSchema, directorySchema } from "../schemas/member.schema";

const SPREADSHEET_ID = process.env.GOOGLE_SHEETS_ID;
const RANGE = "Diretoria!A2:Z";

export async function loadDirectory() {
  const sheets = google.sheets({ version: "v4", auth: getAuth() });

  const res = await sheets.spreadsheets.values.get({
    spreadsheetId: SPREADSHEET_ID,
    range: RANGE,
  });

  const rows = res.data.values ?? [];
  return rows
    .map(rowToMember)      // Transform row array → object
    .map(m => memberSchema.parse(m));  // Validate with Zod
}
```

**Cloudinary URL Builder (`cloudinary.ts`):**

```typescript
const CLOUD_NAME = process.env.NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME;

export function memberPhotoUrl(
  publicId: string,
  options: { width?: number; height?: number } = {}
) {
  const { width = 400, height = 400 } = options;
  return `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/` +
    `w_${width},h_${height},c_fill,g_face,f_auto,q_auto/` +
    `members/${publicId}`;
}
```

### 5.4 Estratégia de Rendering (ISR)

A melhor estratégia para dados que mudam 1-2x/ano com o Next.js atual:

```typescript
// app/[locale]/page.tsx
import { loadDirectory } from "@/data/loaders/loadDirectory";
import { loadTeams } from "@/data/loaders/loadTeams";

// ISR: revalidate every hour
export const revalidate = 3600;

export default async function Home() {
  const [directory, teams, partners] = await Promise.all([
    loadDirectory(),
    loadTeams(),
    loadPartners(),
  ]);

  return (
    <div>
      {/* Pass data as props to client components */}
      <DirectorySection data={directory} />
      <PartnersSection data={partners} />
    </div>
  );
}
```

**Benefícios:**
- Página renderiza estaticamente, revalida a cada hora
- Se Sheets estiver fora do ar, serve versão cacheada
- Zero latência para o usuário (HTML pré-renderizado)
- Atualização aparece no site em ≤1 hora após edição na Sheet

> [!IMPORTANT]
> **On-demand revalidation** também é possível: um webhook (ou botão admin) chama `revalidatePath("/")` para forçar atualização imediata. Pode ser implementado com uma API route protegida por secret.

